# Copy to .env.local and fill in values
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/corp_hq"

# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET="replace_with_64_char_hex"
JWT_REFRESH_SECRET="replace_with_another_64_char_hex"

JWT_ACCESS_EXPIRY="15m"
JWT_REFRESH_EXPIRY="7d"

NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Password reset email via Resend (never commit a real API key)
RESEND_API_KEY="re_replace_with_resend_api_key"
RESEND_FROM="CorpHQ <no-reply@example.com>"

NODE_ENV="development"
